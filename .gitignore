# Generated comparison artifacts under readme-imgs/. Only the originally
# published result images (betta.jpg, revali.jpg, dunwall.jpg, img2plot.jpg)
# are tracked.
readme-imgs/*-original.jpg
readme-imgs/*-ours.*
readme-imgs/*-autoscaled.*
readme-imgs/*-fully-auto*

